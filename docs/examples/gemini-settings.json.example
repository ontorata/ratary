{
  "mcpServers": {
    "ratary": {
      "command": "npx",
      "args": ["-y", "tsx", "REPO_PATH/src/mcp/stdio.ts"],
      "cwd": "REPO_PATH",
      "env": {
        "CLOUDFLARE_ACCOUNT_ID": "your_cloudflare_account_id",
        "D1_DATABASE_ID": "your_d1_database_id",
        "D1_API_TOKEN": "your_cloudflare_api_token",
        "NODE_ENV": "production",
        "LOG_LEVEL": "info"
      },
      "timeout": 60000,
      "trust": false
    }
  }
}
