{
  "version": "1",
  "slos": [
    {
      "id": "memory-search-availability",
      "name": "Memory Search Availability",
      "description": "Ratio of successful memory search requests",
      "target": 0.999,
      "window": "30d",
      "metric": "ai_brain_memory_operations_total",
      "threshold": "status!~\"5..\""
    },
    {
      "id": "memory-search-latency-p99",
      "name": "Memory Search p99 Latency",
      "description": "99th percentile search latency under 500ms",
      "target": 0.99,
      "window": "30d",
      "metric": "ai_brain_memory_search_duration_seconds",
      "threshold": "le=\"0.5\""
    },
    {
      "id": "embedding-error-rate",
      "name": "Embedding Error Rate",
      "description": "Embedding provider error rate below 0.1%",
      "target": 0.999,
      "window": "30d",
      "metric": "ai_brain_embedding_requests_total",
      "threshold": "status=\"error\""
    },
    {
      "id": "federation-sync-freshness",
      "name": "Federation Sync Freshness",
      "description": "Peer sync lag under 5 minutes",
      "target": 0.99,
      "window": "7d",
      "metric": "ai_brain_federation_sync_lag_seconds",
      "threshold": "lt 300"
    }
  ],
  "alerts": [
    {
      "id": "high-error-rate",
      "name": "HighHTTPErrorRate",
      "expr": "sum(rate(ai_brain_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(ai_brain_http_requests_total[5m])) > 0.05",
      "for": "5m",
      "severity": "critical",
      "annotations": {
        "summary": "HTTP 5xx error rate above 5%"
      }
    },
    {
      "id": "high-latency-p99",
      "name": "HighHTTPLatencyP99",
      "expr": "histogram_quantile(0.99, sum(rate(ai_brain_http_request_duration_seconds_bucket[5m])) by (le)) > 2",
      "for": "10m",
      "severity": "warning",
      "annotations": {
        "summary": "HTTP p99 latency above 2s"
      }
    },
    {
      "id": "embedding-failures",
      "name": "EmbeddingFailureSpike",
      "expr": "sum(rate(ai_brain_embedding_requests_total{status=\"error\"}[5m])) > 0.1",
      "for": "5m",
      "severity": "warning",
      "annotations": {
        "summary": "Embedding error rate elevated"
      }
    }
  ]
}
