# Cloudflare D1
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
D1_DATABASE_ID=your_d1_database_id
D1_API_TOKEN=your_cloudflare_api_token

# Identity / Authentication (Phase 2)
# Generate: openssl rand -hex 32
AUTH_SECRET=your_auth_secret_min_32_characters_long

# MCP memory scope (optional — defaults to shared legacy pool '')
# MCP_OWNER_ID=your-owner-uuid-from-bootstrap
# MCP_WORKSPACE_ID=
# MCP_AGENT_ID=

# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Embedding (Phase 5) — default noop; set openai + API key for real vectors
# EMBEDDING_PROVIDER=noop
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_BATCH_SIZE=32

# Hybrid retrieval (Phase 6) — SQL + vector RRF merge
# HYBRID_RETRIEVAL=false

# Graph retrieval (Phase 8) — sql + graph or triple composite (ADR-006)
# GRAPH_RETRIEVAL=false
# GRAPH_MAX_DEPTH=2
# GRAPH_SEED_CAP=5
# GRAPH_MAX_NEIGHBORS=30

# Platform infrastructure (Phase 10) — all opt-in; defaults preserve D1-only behavior
# SQL_PROVIDER=d1
# DATABASE_URL=postgresql://user:pass@localhost:5432/ai_brain
# VECTOR_PROVIDER=d1
# PGVECTOR_DATABASE_URL=
# OBJECT_STORAGE_PROVIDER=inline
# R2_BUCKET_NAME=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ACCOUNT_ID=
# S3_BUCKET_NAME=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=false
# SEARCH_PROVIDER=sql
# MEILISEARCH_HOST=
# MEILISEARCH_API_KEY=
# MEILISEARCH_INDEX=memories
# GRAPH_PROVIDER=d1
# NEO4J_URI=
# NEO4J_USERNAME=
# NEO4J_PASSWORD=
# CACHE_PROVIDER=none
# REDIS_URL=
# RATE_LIMIT_REDIS_URL=redis://default:YOUR_TOKEN@YOUR_HOST.upstash.io:6379
# On Vercel multi-instance: set RATE_LIMIT_REDIS_URL (or REDIS_URL) to Upstash Redis
# REDIS_KEY_PREFIX=ai-brain:cache:
# EVENT_BUS_PROVIDER=none
# REDIS_STREAM_PREFIX=ai-brain:events:
# ANALYTICS_PROVIDER=none
# DUCKDB_PATH=:memory:
# ENTERPRISE_RBAC=false
# MEMORY_ACCESS_AUDIT=false

# Extension tracks (5.5 / 6.5 / 8.5) — default off preserves pre-track behavior
# RETRIEVAL_POLICY_VERSION=1
# COMPRESSION_ENABLED=false
# COMPRESSION_POLICY=rule
# COMPRESSION_SCHEDULER=none
# SIGNAL_INGEST_ENABLED=false
# SIGNAL_STORE_PROVIDER=none
# RANKING_ADAPTATION_ENABLED=false

# Self-managing memory stewardship (Phase 04.7, ADR-045) — deterministic maintenance pipeline
# MEMORY_STEWARDSHIP_ENABLED=false

# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=ai-memory-cloud
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces

# Transport & connectivity (Phase 10.5E) — gRPC opt-in, ADR-027
# Default off: only REST + MCP stdio run. gRPC needs long-running Node (K8s/VM), not Vercel.
# GRPC_ENABLED=false
# GRPC_PORT=50051          # 0 = OS-assigned ephemeral port
# GRPC_HOST=0.0.0.0
# GRPC_TLS_CERT_PATH=      # optional mTLS — set both cert + key together
# GRPC_TLS_KEY_PATH=

# Backup auto-sync (scripts/sync-backups.ts)
BACKUP_ROOT=D:/Apps/_backups
BACKUP_SYNC_DEBOUNCE_MS=3000
BACKUP_SYNC_POLL_MS=30000
