# Ratary environment template
# Copy to .env — never commit .env
# What each variable does: docs/CONFIGURATION.md
# Setup workflows: docs/GUIDE.md

# Cloudflare D1 (when SQL_PROVIDER=d1)
# CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
# D1_DATABASE_ID=your_d1_database_id
# D1_API_TOKEN=your_cloudflare_api_token

# Identity / Authentication (Phase 2)
# Generate: openssl rand -hex 32
AUTH_SECRET=your_auth_secret_min_32_characters_long

# MCP memory scope (optional — defaults to shared legacy pool '')
# MCP_OWNER_ID=your-owner-uuid-from-bootstrap
# MCP_WORKSPACE_ID=
# MCP_AGENT_ID=

# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Embedding (Phase 5) — default noop; set openai + API key for real vectors
# EMBEDDING_PROVIDER=noop
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_BATCH_SIZE=32
# EMBEDDING_JOB_MAX_MEMORIES=10000

# Hybrid retrieval (Phase 6) — SQL + vector RRF merge
# HYBRID_RETRIEVAL=false

# Graph retrieval (Phase 8) — sql + graph or triple composite (ADR-006)
# GRAPH_RETRIEVAL=false
# GRAPH_MAX_DEPTH=2
# GRAPH_SEED_CAP=5
# GRAPH_MAX_NEIGHBORS=30

# Platform infrastructure (Phase 10) — pick SQL_PROVIDER + optional adapters; see CONFIGURATION Tier 0–2
SQL_PROVIDER=postgres
DATABASE_URL=postgresql://user:pass@localhost:5432/ratary
# SQL_PROVIDER=d1|mariadb|mysql|tidb|cockroachdb|supabase — see CONFIGURATION.md
# MARIADB_CONNECTION_STRING=mysql://user:pass@localhost:3306/ratary
# SQL_PROVIDER=tidb|cockroachdb|supabase use DATABASE_URL (Postgres wire protocol)
# Supabase example:
# SQL_PROVIDER=supabase
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# VECTOR_PROVIDER=d1
# PGVECTOR_DATABASE_URL=
# OBJECT_STORAGE_PROVIDER=inline
# R2_BUCKET_NAME=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ACCOUNT_ID=
# S3_BUCKET_NAME=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=false
# MinIO (S3-compatible on-prem) — OBJECT_STORAGE_PROVIDER=minio
# MINIO_ENDPOINT=http://127.0.0.1:9000
# MINIO_BUCKET=ratary
# MINIO_ACCESS_KEY_ID=
# MINIO_SECRET_ACCESS_KEY=
# MINIO_REGION=us-east-1
# MINIO_USE_SSL=false
# Azure Blob — OBJECT_STORAGE_PROVIDER=azure
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_CONTAINER_NAME=
# Google Cloud Storage — OBJECT_STORAGE_PROVIDER=gcs
# GCS_BUCKET_NAME=
# GCS_KEY_FILE=/path/to/service-account.json
# SEARCH_PROVIDER=sql
# MEILISEARCH_HOST=
# MEILISEARCH_API_KEY=
# MEILISEARCH_INDEX=memories
# OPENSEARCH_NODE=http://127.0.0.1:9200
# OPENSEARCH_INDEX=memories
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=
# GRAPH_PROVIDER=d1
# GRAPH_PROVIDER=neptune
# NEPTUNE_ENDPOINT=https://your-neptune-cluster.region.neptune.amazonaws.com
# NEO4J_URI=
# NEO4J_USERNAME=
# NEO4J_PASSWORD=
# CACHE_PROVIDER=none
# REDIS_URL=
# RATE_LIMIT_REDIS_URL=redis://default:YOUR_TOKEN@YOUR_HOST.upstash.io:6379
# On Vercel multi-instance: set RATE_LIMIT_REDIS_URL (or REDIS_URL) to Upstash Redis
# REDIS_KEY_PREFIX=ai-brain:cache:
# EVENT_BUS_PROVIDER=none
# EVENT_CONSUMERS_ENABLED=false
# REDIS_STREAM_PREFIX=ai-brain:events:
# ANALYTICS_PROVIDER=none
# DUCKDB_PATH=:memory:
# CLICKHOUSE_URL=http://127.0.0.1:8123
# CLICKHOUSE_DATABASE=ratary
# CLICKHOUSE_USERNAME=default
# CLICKHOUSE_PASSWORD=
# ENTERPRISE_RBAC=false
# MEMORY_ACCESS_AUDIT=false

# Enterprise security (Phase 17, ADR-032) — default off preserves Phase 10 behavior
# Policy samples (Rego): docs/policies/ — load into OPA; set POLICY_ENGINE=opa + OPA_URL
# ENTERPRISE_SECURITY_V2=false
# POLICY_ENGINE=none
# OPA_URL=http://127.0.0.1:8181
# SSO_ENABLED=false
# OIDC_ISSUER_URL=https://login.example.com/realms/ai-brain
# OIDC_CLIENT_ID=ai-brain-client
# OIDC_CLIENT_SECRET=
# QUOTA_ENFORCER=none
# QUOTA_MAX_REQUESTS_PER_MINUTE=1000
# QUOTA_MAX_WRITES_PER_DAY=10000

# Extension tracks (5.5 / 6.5 / 8.5) — default off preserves pre-track behavior
# RETRIEVAL_POLICY=default
# RETRIEVAL_POLICY=legacy
# RETRIEVAL_POLICY=adaptive
# RETRIEVAL_POLICY_VERSION=1
# One-hop relation neighbors in get_context relations stage (requires GRAPH_RETRIEVAL=true).
# Default 5 is safe for most deploys. Dense graphs / noisy context: try 3; sparse graphs needing more direct neighbors: 8-10 (max 30).
# See docs/GUIDE.md — Hybrid & graph retrieval — dense graph tuning.
# RETRIEVAL_RELATION_NEIGHBOR_CAP=5
# COMPRESSION_ENABLED=false
# COMPRESSION_POLICY=rule
# COMPRESSION_SCHEDULER=none          # local = async in-process queue (D55-01)
# SUMMARIZER_API_KEY=          # optional; falls back to EMBEDDING_API_KEY when COMPRESSION_POLICY=llm
# SUMMARIZER_MODEL=gpt-4o-mini
# SUMMARIZER_BASE_URL=         # optional OpenAI-compatible endpoint
# SIGNAL_INGEST_ENABLED=false
# SIGNAL_STORE_PROVIDER=none
# RANKING_ADAPTATION_ENABLED=false

# Learning intelligence engine (Phase 8.6, ADR-057) — async policy snapshots from signals
# LEARNING_ENGINE_ENABLED=false
# LEARNING_STORE_PROVIDER=none

# Inspection pattern ledger (Phase 8.8, ADR-059) — inspection_outcome signals + future pattern miner
# INSPECTION_LEDGER_ENABLED=false
# INSPECTION_LEDGER_STORE_PROVIDER=none
# INSPECTION_CHARTER_ENABLED=false

# Precision search platform (Phase 6.6, ADR-060) — structured filters, path-aware search
# PRECISION_SEARCH_ENABLED=false
# SEARCH_IGNORE_PATTERNS=node_modules/**,.git/**
# SEARCH_DEFAULT_MODE=hybrid
# MULTI_QUERY_RRF_K=60
# SEARCH_MAX_QUERIES=5
# ALIAS_EXACT_BOOST=500
# TITLE_FUZZY_BOOST=3
# SEARCH_ENRICH_LINK_CAP=20
# SEARCH_RERANK_ENABLED=false
# RERANK_MODEL_PATH=
# EMBEDDING_PROVIDER=local

# Graph relation inference (Phase 8.7, ADR-041) — async inferred memory_relations edges
# RELATION_INFERENCE_ENABLED=false
# RELATION_INFERENCE_STORE_PROVIDER=none

# Memory evolution & version control (Phase 09.7, ADR-040) — immutable version chain, restore, merge
# MEMORY_EVOLUTION_ENABLED=false
# MEMORY_EVOLUTION_STORE_PROVIDER=none

# Multi-client memory sync (Phase 09.8, ADR-042) — pull/push with conflict resolution
# MULTI_CLIENT_SYNC_ENABLED=false
# MULTI_CLIENT_SYNC_STORE_PROVIDER=none
# MULTI_CLIENT_SYNC_STRATEGY=lww

# Self-managing memory stewardship (Phase 04.7, ADR-045) — deterministic maintenance pipeline
# MEMORY_STEWARDSHIP_ENABLED=false
# MEMORY_STEWARDSHIP_RUN_STORE_PROVIDER=memory
# MEMORY_STEWARDSHIP_SCHEDULER=none

# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=ratary
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces

# Transport & connectivity (Phase 10.5E) — gRPC opt-in, ADR-027
# Default off: only REST + MCP stdio run. gRPC needs long-running Node (K8s/VM), not Vercel.
# GRPC_ENABLED=false
# GRPC_PORT=50051          # 0 = OS-assigned ephemeral port
# GRPC_HOST=0.0.0.0
# GRPC_TLS_CERT_PATH=      # optional mTLS — set both cert + key together
# GRPC_TLS_KEY_PATH=

# Protocol layer (Phase 13, ADR-028) — streaming adapters, default off
# SSE_ENABLED=false
# SSE_MAX_CONCURRENT_PER_IP=10
# SSE_STREAM_RATE_LIMIT_MAX=30
# SSE_STREAM_RATE_LIMIT_WINDOW=1 minute
# WEBSOCKET_ENABLED=false
# WEBSOCKET_PATH=/api/v1/ws

# Remote MCP for ChatGPT / web clients (Phase 13.1, ADR-048) — default off
# Requires long-running Node host (not Vercel serverless for SSE sessions)
# REMOTE_MCP_ENABLED=false
# REMOTE_MCP_PATH=/mcp
# REMOTE_MCP_CORS_ORIGINS=*
# REMOTE_MCP_PUBLIC_URL=https://your-host.example.com/mcp
# REMOTE_MCP_OAUTH_ENABLED=false
# REMOTE_MCP_PERSISTENT_HOST_ACKNOWLEDGED=false   # required true in production when REMOTE_MCP_ENABLED
# OIDC_MCP_OWNER_ID=00000000-0000-4000-8000-000000000001

# Federation layer (Phase 14, ADR-029) — cross-node knowledge exchange, default off
# FEDERATION_ENABLED=false
# FEDERATION_NODE_ID=00000000-0000-4000-8000-000000000001
# FEDERATION_NODE_DISPLAY_NAME=ratary
# FEDERATION_NODE_REGION=
# FEDERATION_NODE_CLOUD=
# FEDERATION_NODE_BASE_URL=
# FEDERATION_PEERS_JSON=[]
# FEDERATION_REGISTRY_PROVIDER=static
# FEDERATION_TRANSPORT_PROVIDER=in-process
# FEDERATION_TRUST_PROVIDER=noop   # noop | registry | file — production auto-uses registry strict trust
# FEDERATION_TRUST_FILE_PATH=docs/examples/federation-trusted-peers.json
# FEDERATION_POLICY_PROVIDER=rule-based
# FEDERATION_METADATA_PROVIDER=none

# Cloud platform (Phase 18) — ADR-033; control plane metadata orchestration, default off
# CONTROL_PLANE_ENABLED=false
# USAGE_METER_ENABLED=false
# DR_PLATFORM_ENABLED=false
# CLOUD_DEFAULT_REGION=local
# CLOUD_PROVISIONER=manual
# USAGE_METER_STORE=memory

# Observability platform (Phase 19) — ADR-034; metrics/traces/logs export, default off
# OBSERVABILITY_PLATFORM=false
# OBS_METRICS_PATH=/metrics
# OBS_LOG_SHIPPER=stdout
# OBS_LOKI_PUSH_URL=
# OBS_COST_METRICS_ENABLED=false
# COST_EMBEDDING_USD_PER_REQUEST=0.00002
# COST_ESTIMATED_BYTES_PER_MEMORY=4096
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=ratary
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces

# AI infrastructure platform (Phase 20) — ADR-035; plugin marketplace, default off
# Catalog file: infrastructure/marketplace/catalog.json
# PLUGIN_MARKETPLACE_ENABLED=false
# PLUGIN_SIGNATURE_REQUIRED=false
# PLUGIN_TRUSTED_PUBLIC_KEYS=   # comma-separated base64 raw Ed25519 public keys (32 bytes)
# PLUGIN_MARKETPLACE_SOURCE=local
# PLUGIN_FEDERATION_CATALOG_SYNC=false

# Search & graph production (Phase 21) — ADR-022; Meilisearch/Neo4j sync ops, default off
# SEARCH_GRAPH_PLATFORM_ENABLED=false
# GRAPH_VECTOR_SEEDS_ENABLED=false

# Content & vector scale (Phase 22) — ADR-021; R2/pgvector/embedding ops, default off
# CONTENT_SCALE_PLATFORM_ENABLED=false
# CONTENT_OFFLOAD_MIN_BYTES=8192
# CONTENT_OFFLOAD_CLEAR_INLINE=false

# Enterprise knowledge fabric (Phase 23) — ADR-047; external connector ingest, default off
# KNOWLEDGE_FABRIC_ENABLED=false
# KNOWLEDGE_FABRIC_CATALOG_JSON={}
# NOTION_API_TOKEN=
# NOTION_API_VERSION=2022-06-28
# CONFLUENCE_BASE_URL=https://your-domain.atlassian.net
# CONFLUENCE_EMAIL=you@company.com
# CONFLUENCE_API_TOKEN=
# CONNECTOR_SYNC_ENABLED=false
# CONNECTOR_WEBHOOK_SECRET=
# CONNECTOR_SYNC_INTERVAL_MS=0
# GITHUB_TOKEN=

# Ratary platform umbrella (Phase 24) — ADR-044; edition + webhooks, default off
# RATARY_PLATFORM_ENABLED=false
# RATARY_PLATFORM_EDITION=core
# PLATFORM_WEBHOOKS_ENABLED=false

# Ratary MCP / CLI client (remote REST via @ratary/mcp-server or @ratary/cli)
# Remote REST / Studio
#   npm run key:create -- --url https://ratary.ontorata.com
#   npm run key:list   -- --key aic_...
#   npm run key:rotate -- --key aic_... --name studio-vercel
# RATARY_BASE_URL=https://ratary.ontorata.com
# RATARY_API_KEY=aic_...
# RATARY_WORKSPACE_ID=
# RATARY_FEDERATION=false
# Legacy aliases still accepted: AI_BRAIN_BASE_URL, AI_BRAIN_API_KEY, AI_BRAIN_WORKSPACE_ID

# Backup auto-sync (scripts/sync-backups.ts)
BACKUP_ROOT=D:/Apps/_backups
BACKUP_SYNC_DEBOUNCE_MS=3000
BACKUP_SYNC_POLL_MS=30000
