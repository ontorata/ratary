# =============================================================================
# Ratary — environment template
# =============================================================================
# Copy to `.env` — never commit `.env`
# Docs: docs/CONFIGURATION.md#tier-0--core-required-sql--auth--mcp
#       docs/GUIDE.md#1-setup
#       docs/PRODUCTION-ENABLE.md (hosted deploy)
#
# QUICK START (local MCP — stop after Tier 1)
#   1. cp .env.example .env
#   2. Set AUTH_SECRET (openssl rand -hex 32) and DATABASE_URL below
#   3. Postgres: npm run db:apply-postgres-schema  |  D1: npm run db:migrate
#   4. npm run setup
#   Sections 2+ below are optional — skip on first install.
#
# TABLE OF CONTENTS#   1. Tier 0 — Core (auth, server, MCP scope)
#   2. Tier 1 — SQL metadata store (pick one provider)
#   3. Tier 2 — Platform adapters (vectors, storage, search, graph, cache, events)
#   4. Tier 3 — Retrieval (embedding, hybrid, graph traversal)
#   5. Extension tracks (4.7–9.8, 6.6 precision search)
#   6. Transport & protocol (10.5 gRPC, 13 SSE/WS, 13.1 remote MCP)
#   7. Enterprise platform (14–25, default OFF)
#   8. Client SDK / CLI (local operator tools)
#   9. Backup sync (local dev scripts)
#
# Convention: uncomment a line to opt in. Commented lines show defaults.
# =============================================================================


# =============================================================================
# 1. TIER 0 — CORE
# =============================================================================

# --- Identity / authentication (Phase 2) ---
# Replace placeholder before deploy. Generate: openssl rand -hex 32
AUTH_SECRET=your_auth_secret_min_32_characters_long

# --- Server ---
# Production: set NODE_ENV=production, rotate AUTH_SECRET — see docs/PRODUCTION-ENABLE.md
NODE_ENV=developmentPORT=3000
LOG_LEVEL=info

# --- MCP memory scope (optional — defaults to shared legacy pool '') ---
# MCP_OWNER_ID=your-owner-uuid-from-bootstrap
# MCP_WORKSPACE_ID=
# MCP_AGENT_ID=


# =============================================================================
# 2. TIER 1 — SQL METADATA STORE (pick one SQL_PROVIDER)
# =============================================================================
# Peer choices: postgres | supabase | d1 | mariadb | mysql | tidb | cockroachdb
# See docs/CONFIGURATION.md#sql-metadata-store-choose-one

# --- PostgreSQL (template default) ---
# Use when: local/docker self-host (default path). Docker: docs/DOCKER.md
SQL_PROVIDER=postgres
DATABASE_URL=postgresql://user:pass@localhost:5432/ratary

# --- Cloudflare D1 ---
# Use when: serverless on Cloudflare; no RDBMS to manage
# SQL_PROVIDER=d1
# CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
# D1_DATABASE_ID=your_d1_database_id
# D1_API_TOKEN=your_cloudflare_api_token

# --- MariaDB ---
# Use when: existing MariaDB fleet / on-prem MySQL-compatible DB
# SQL_PROVIDER=mariadb
# MARIADB_CONNECTION_STRING=mysql://user:pass@localhost:3306/ratary

# --- MySQL ---
# Use when: same as MariaDB; uses MARIADB_CONNECTION_STRING
# SQL_PROVIDER=mysql
# MARIADB_CONNECTION_STRING=mysql://user:pass@localhost:3306/ratary

# --- TiDB ---
# Use when: distributed SQL; Postgres wire protocol
# SQL_PROVIDER=tidb
# DATABASE_URL=postgresql://user:pass@host:4000/ratary

# --- CockroachDB ---
# Use when: distributed SQL; Postgres wire protocol
# SQL_PROVIDER=cockroachdb
# DATABASE_URL=postgresql://user:pass@host:26257/ratary?sslmode=disable

# --- Supabase ---
# Use when: managed Postgres (+ optional pgvector from dashboard)
# SQL_PROVIDER=supabase
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# =============================================================================
# 3. TIER 2 — PLATFORM ADAPTERS (optional — default OFF / inline)
# =============================================================================

# --- Vector store ---
# VECTOR_PROVIDER=d1
# PGVECTOR_DATABASE_URL=

# --- Object storage (OBJECT_STORAGE_PROVIDER=inline|r2|s3|minio|azure|gcs) ---

# R2 (Cloudflare)
# OBJECT_STORAGE_PROVIDER=r2
# R2_BUCKET_NAME=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ACCOUNT_ID=

# S3-compatible
# OBJECT_STORAGE_PROVIDER=s3
# S3_BUCKET_NAME=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=false

# MinIO (on-prem S3)
# OBJECT_STORAGE_PROVIDER=minio
# MINIO_ENDPOINT=http://127.0.0.1:9000
# MINIO_BUCKET=ratary
# MINIO_ACCESS_KEY_ID=
# MINIO_SECRET_ACCESS_KEY=
# MINIO_REGION=us-east-1
# MINIO_USE_SSL=false

# Azure Blob
# OBJECT_STORAGE_PROVIDER=azure
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_CONTAINER_NAME=

# Google Cloud Storage
# OBJECT_STORAGE_PROVIDER=gcs
# GCS_BUCKET_NAME=
# GCS_KEY_FILE=/path/to/service-account.json

# --- Lexical search (SEARCH_PROVIDER=sql|meilisearch|opensearch) ---
# SEARCH_PROVIDER=sql
# MEILISEARCH_HOST=
# MEILISEARCH_API_KEY=
# MEILISEARCH_INDEX=memories
# OPENSEARCH_NODE=http://127.0.0.1:9200
# OPENSEARCH_INDEX=memories
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=

# --- Graph store backend (GRAPH_PROVIDER=d1|neo4j|neptune) ---
# Where relation edges are stored. Pair with GRAPH_RETRIEVAL in Tier 3 to use graph in context.
# GRAPH_PROVIDER=d1
# NEO4J_URI=
# NEO4J_USERNAME=
# NEO4J_PASSWORD=
# GRAPH_PROVIDER=neptune
# NEPTUNE_ENDPOINT=https://your-neptune-cluster.region.neptune.amazonaws.com
# --- Cache & rate limiting ---
# CACHE_PROVIDER=none
# REDIS_URL=
# RATE_LIMIT_REDIS_URL=redis://default:YOUR_TOKEN@YOUR_HOST.upstash.io:6379
# REDIS_KEY_PREFIX=ratary:cache:
# Vercel multi-instance: set RATE_LIMIT_REDIS_URL (or REDIS_URL) to Upstash Redis

# --- Event bus & consumers (Phase 12) ---
# EVENT_BUS_PROVIDER=none
# EVENT_CONSUMERS_ENABLED=false
# REDIS_STREAM_PREFIX=ratary:events:

# --- Analytics ---
# ANALYTICS_PROVIDER=none
# DUCKDB_PATH=:memory:
# CLICKHOUSE_URL=http://127.0.0.1:8123
# CLICKHOUSE_DATABASE=ratary
# CLICKHOUSE_USERNAME=default
# CLICKHOUSE_PASSWORD=

# --- Audit & RBAC ---
# MEMORY_ACCESS_AUDIT=false
# ENTERPRISE_RBAC=false


# =============================================================================
# 4. TIER 3 — RETRIEVAL (OPTIONAL — skip unless you need vectors or graph context)
# =============================================================================
# --- Embedding (Phase 5) — default noop; set openai + API key for real vectors ---
# EMBEDDING_PROVIDER=noop
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_BATCH_SIZE=32
# EMBEDDING_JOB_MAX_MEMORIES=10000

# --- Hybrid retrieval (Phase 6) — SQL + vector RRF merge ---
# HYBRID_RETRIEVAL=false

# --- Graph retrieval (Phase 8) — sql + graph or triple composite (ADR-006) ---
# Enables graph in get_context. Requires GRAPH_PROVIDER (Tier 2) and memory_relations data.
# GRAPH_RETRIEVAL=false# GRAPH_MAX_DEPTH=2
# GRAPH_SEED_CAP=5
# GRAPH_MAX_NEIGHBORS=30

# --- Retrieval policy tuning ---
# RETRIEVAL_POLICY=default
# RETRIEVAL_POLICY_VERSION=1
# RETRIEVAL_RELATION_NEIGHBOR_CAP=5
# One-hop relation neighbors in get_context (requires GRAPH_RETRIEVAL=true).
# Default 5 — dense graphs: 3; sparse: 8–10 (max 30). See docs/GUIDE.md.


# =============================================================================
# 5. EXTENSION TRACKS (default OFF)
# =============================================================================

# --- Phase 4.7 — Memory stewardship (ADR-045) ---
# MEMORY_STEWARDSHIP_ENABLED=false
# MEMORY_STEWARDSHIP_RUN_STORE_PROVIDER=memory
# MEMORY_STEWARDSHIP_SCHEDULER=none

# --- Phase 5.5 — Semantic compression ---
# COMPRESSION_ENABLED=false
# COMPRESSION_POLICY=rule
# COMPRESSION_SCHEDULER=none
# SUMMARIZER_API_KEY=
# SUMMARIZER_MODEL=gpt-4o-mini
# SUMMARIZER_BASE_URL=

# --- Phase 6.6 — Precision search (ADR-060) ---
# PRECISION_SEARCH_ENABLED=false
# SEARCH_IGNORE_PATTERNS=node_modules/**,.git/**
# SEARCH_DEFAULT_MODE=hybrid
# MULTI_QUERY_RRF_K=60
# SEARCH_MAX_QUERIES=5
# ALIAS_EXACT_BOOST=500
# TITLE_FUZZY_BOOST=3
# SEARCH_ENRICH_LINK_CAP=20
# SEARCH_RERANK_ENABLED=false
# RERANK_MODEL_PATH=

# --- Phase 8.5 — Quality signals ---
# SIGNAL_INGEST_ENABLED=false
# SIGNAL_STORE_PROVIDER=none
# RANKING_ADAPTATION_ENABLED=false

# --- Phase 8.6 — Learning intelligence (ADR-057) ---
# LEARNING_ENGINE_ENABLED=false
# LEARNING_STORE_PROVIDER=none

# --- Phase 8.7 — Graph relation inference (ADR-041) ---
# RELATION_INFERENCE_ENABLED=false
# RELATION_INFERENCE_STORE_PROVIDER=none

# --- Phase 8.8 — Inspection pattern ledger (ADR-059) ---
# INSPECTION_LEDGER_ENABLED=false
# INSPECTION_LEDGER_STORE_PROVIDER=none
# INSPECTION_CHARTER_ENABLED=false

# --- Phase 9.7 — Memory evolution (ADR-040) ---
# MEMORY_EVOLUTION_ENABLED=false
# MEMORY_EVOLUTION_STORE_PROVIDER=none

# --- Phase 9.8 — Multi-client sync (ADR-042) ---
# MULTI_CLIENT_SYNC_ENABLED=false
# MULTI_CLIENT_SYNC_STORE_PROVIDER=none
# MULTI_CLIENT_SYNC_STRATEGY=lww


# =============================================================================
# 6. TRANSPORT & PROTOCOL (default OFF)
# =============================================================================

# --- Phase 10.5 — gRPC (ADR-027) ---
# Long-running Node only (K8s/VM) — not Vercel serverless
# GRPC_ENABLED=false
# GRPC_PORT=50051
# GRPC_HOST=0.0.0.0
# GRPC_TLS_CERT_PATH=
# GRPC_TLS_KEY_PATH=

# --- Phase 13 — Protocol layer (ADR-028) ---
# SSE_ENABLED=false
# SSE_MAX_CONCURRENT_PER_IP=10
# SSE_STREAM_RATE_LIMIT_MAX=30
# SSE_STREAM_RATE_LIMIT_WINDOW=1 minute
# WEBSOCKET_ENABLED=false
# WEBSOCKET_PATH=/api/v1/ws

# --- Phase 13.1 — Remote MCP (ADR-048) ---
# Long-running host required — not Vercel serverless for persistent sessions
# REMOTE_MCP_ENABLED=false
# REMOTE_MCP_PATH=/mcp
# REMOTE_MCP_CORS_ORIGINS=*
# REMOTE_MCP_PUBLIC_URL=https://your-host.example.com/mcp
# REMOTE_MCP_OAUTH_ENABLED=false
# REMOTE_MCP_PERSISTENT_HOST_ACKNOWLEDGED=false
# OIDC_MCP_OWNER_ID=00000000-0000-4000-8000-000000000001


# =============================================================================
# 7. ENTERPRISE PLATFORM (default OFF)
# =============================================================================

# --- Phase 14 — Federation (ADR-029) ---
# FEDERATION_ENABLED=false
# FEDERATION_NODE_ID=00000000-0000-4000-8000-000000000001
# FEDERATION_NODE_DISPLAY_NAME=ratary
# FEDERATION_NODE_REGION=
# FEDERATION_NODE_CLOUD=
# FEDERATION_NODE_BASE_URL=
# FEDERATION_PEERS_JSON=[]
# FEDERATION_REGISTRY_PROVIDER=static
# FEDERATION_TRANSPORT_PROVIDER=in-process
# FEDERATION_TRUST_PROVIDER=noop
# FEDERATION_TRUST_FILE_PATH=docs/examples/federation-trusted-peers.json
# FEDERATION_POLICY_PROVIDER=rule-based
# FEDERATION_METADATA_PROVIDER=none

# --- Phase 17 — Enterprise security (ADR-032) ---
# Policy samples: docs/policies/ — load into OPA; set POLICY_ENGINE=opa + OPA_URL
# ENTERPRISE_SECURITY_V2=false
# POLICY_ENGINE=none
# OPA_URL=http://127.0.0.1:8181
# SSO_ENABLED=false
# OIDC_ISSUER_URL=https://login.example.com/realms/ratary
# OIDC_CLIENT_ID=ratary-client
# OIDC_CLIENT_SECRET=
# QUOTA_ENFORCER=none
# QUOTA_MAX_REQUESTS_PER_MINUTE=1000
# QUOTA_MAX_WRITES_PER_DAY=10000

# --- Phase 18 — Cloud platform (ADR-033) ---
# CONTROL_PLANE_ENABLED=false
# USAGE_METER_ENABLED=false
# DR_PLATFORM_ENABLED=false
# CLOUD_DEFAULT_REGION=local
# CLOUD_PROVISIONER=manual
# USAGE_METER_STORE=memory

# --- Phase 19 — Observability (ADR-034) ---
# OBSERVABILITY_PLATFORM=false
# OBS_METRICS_PATH=/metrics
# OBS_LOG_SHIPPER=stdout
# OBS_LOKI_PUSH_URL=
# OBS_COST_METRICS_ENABLED=false
# COST_EMBEDDING_USD_PER_REQUEST=0.00002
# COST_ESTIMATED_BYTES_PER_MEMORY=4096
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=ratary
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces

# --- Phase 20 — Plugin marketplace (ADR-035) ---
# Catalog: infrastructure/marketplace/catalog.json
# PLUGIN_MARKETPLACE_ENABLED=false
# PLUGIN_SIGNATURE_REQUIRED=false
# PLUGIN_TRUSTED_PUBLIC_KEYS=
# PLUGIN_MARKETPLACE_SOURCE=local
# PLUGIN_FEDERATION_CATALOG_SYNC=false

# --- Phase 21 — Search & graph production (ADR-022) ---
# SEARCH_GRAPH_PLATFORM_ENABLED=false
# GRAPH_VECTOR_SEEDS_ENABLED=false

# --- Phase 22 — Content & vector scale (ADR-021) ---
# CONTENT_SCALE_PLATFORM_ENABLED=false
# CONTENT_OFFLOAD_MIN_BYTES=8192
# CONTENT_OFFLOAD_CLEAR_INLINE=false

# --- Phase 23 — Knowledge fabric (ADR-047) ---
# KNOWLEDGE_FABRIC_ENABLED=false
# KNOWLEDGE_FABRIC_CATALOG_JSON={}
# CONNECTOR_SYNC_ENABLED=false
# CONNECTOR_WEBHOOK_SECRET=
# CONNECTOR_SYNC_INTERVAL_MS=0
# NOTION_API_TOKEN=
# NOTION_API_VERSION=2022-06-28
# CONFLUENCE_BASE_URL=https://your-domain.atlassian.net
# CONFLUENCE_EMAIL=you@company.com
# CONFLUENCE_API_TOKEN=
# GITHUB_TOKEN=
# GITLAB_TOKEN=
# JIRA_API_TOKEN=
# SLACK_BOT_TOKEN=
# GOOGLE_DRIVE_CREDENTIALS_JSON=
# SHAREPOINT_CLIENT_SECRET=
# FABRIC_EMAIL_IMAP_URL=
# TEAMS_WEBHOOK_URL=

# --- Phase 24 — Ratary platform umbrella (ADR-044) ---
# RATARY_PLATFORM_ENABLED=false
# RATARY_PLATFORM_EDITION=core
# PLATFORM_WEBHOOKS_ENABLED=false

# --- Phase 25 — Global intelligence (ADR-036) ---
# GLOBAL_INTELLIGENCE_PLATFORM_ENABLED=false
# TELEMETRY_CONTENT_SAMPLING=false


# =============================================================================
# 8. CLIENT SDK / CLI (local operator — not server runtime)
# =============================================================================
# npm run key:create -- --url https://ratary.ontorata.com
# npm run key:list   -- --key aic_...
# npm run key:rotate -- --key aic_... --name studio
# RATARY_BASE_URL=https://ratary.ontorata.com
# RATARY_API_KEY=aic_...
# RATARY_WORKSPACE_ID=
# RATARY_FEDERATION=false
# Legacy aliases: AI_BRAIN_BASE_URL, AI_BRAIN_API_KEY, AI_BRAIN_WORKSPACE_ID


# =============================================================================
# 9. BACKUP SYNC — LOCAL DEV ONLY (not required for server deploy)
# =============================================================================
# scripts/sync-backups.ts — optional file watcher for D:\Apps\_backups-style workflows
# BACKUP_ROOT=/path/to/backups
# BACKUP_SYNC_DEBOUNCE_MS=3000
# BACKUP_SYNC_POLL_MS=30000