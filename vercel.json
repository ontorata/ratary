{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install --include=dev",
  "buildCommand": "echo \"Ratary: @vercel/node bundles api/index.ts — no tsc build step\"",
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "includeFiles": "src/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
