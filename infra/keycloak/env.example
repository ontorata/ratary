# Keycloak IdP for Ratary MCP OAuth (ChatGPT / DCR clients)
# Copy to .env and set KC_ADMIN_PASSWORD before: .\scripts\keycloak-up.ps1

KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=change-me-before-start
KC_HTTP_PORT=8080
# Production: auth.ontorata.com (Render) — not Vercel
KC_HOSTNAME=localhost

# Optional demo user for OAuth smoke (scripts/keycloak-create-demo-user.ps1)
# KC_DEMO_USERNAME=demo
# KC_DEMO_PASSWORD=change-me
# KC_DEMO_EMAIL=demo@example.com
