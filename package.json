{
  "name": "ai-memory-cloud",
  "version": "1.0.0",
  "description": "AI Memory Cloud - Second brain for AI coding assistants powered by Cloudflare D1",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "tsx watch src/dev-server.ts",
    "build": "npm run typecheck",
    "build:local": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:postgres-staging": "vitest run tests/db/postgres-staging.integration.test.ts",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "mcp": "tsx src/mcp/stdio.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:apply-postgres-schema": "tsx scripts/apply-postgres-schema.ts",
    "db:backfill-d1-to-postgres": "tsx scripts/backfill-d1-to-postgres.ts",
    "db:backfill-d1-to-postgres:execute": "tsx scripts/backfill-d1-to-postgres.ts --execute",
    "db:verify-postgres-parity": "tsx scripts/verify-postgres-parity.ts",
    "db:backfill-knowledge": "tsx scripts/backfill-knowledge.ts",
    "db:backfill-memory-intelligence": "tsx scripts/backfill-memory-intelligence.ts",
    "db:backfill-embeddings": "tsx scripts/backfill-embeddings.ts",
    "db:backfill-embeddings:execute": "tsx scripts/backfill-embeddings.ts --execute",
    "db:backfill-workspaces": "tsx scripts/backfill-workspaces.ts",
    "db:backfill-pgvector": "tsx scripts/backfill-pgvector.ts",
    "db:backfill-pgvector:execute": "tsx scripts/backfill-pgvector.ts --execute",
    "db:backfill-meilisearch": "tsx scripts/backfill-meilisearch.ts",
    "db:backfill-meilisearch:execute": "tsx scripts/backfill-meilisearch.ts --execute",
    "db:backfill-neo4j": "tsx scripts/backfill-neo4j.ts",
    "db:backfill-neo4j:execute": "tsx scripts/backfill-neo4j.ts --execute",
    "consolidate:memories": "tsx scripts/consolidate-memories.ts",
    "consolidate:memories:execute": "tsx scripts/consolidate-memories.ts --execute",
    "compress:memories": "tsx scripts/compress-memories.ts",
    "compress:memories:execute": "tsx scripts/compress-memories.ts --execute",
    "reflect:signals": "tsx scripts/reflect-signals.ts",
    "reflect:signals:execute": "tsx scripts/reflect-signals.ts --execute",
    "steward:memories": "tsx scripts/steward-memories.ts",
    "steward:memories:execute": "tsx scripts/steward-memories.ts --execute",
    "benchmark:context-tokens": "tsx scripts/benchmark-context-tokens.ts",
    "test:integration": "tsx scripts/test-integration.ts",
    "import:backups": "tsx scripts/import-backups.ts",
    "import:backups:dry": "tsx scripts/import-backups.ts --dry-run",
    "import:transcript": "tsx scripts/import-backups.ts --file",
    "import:folder": "tsx scripts/import-backups.ts",
    "sync:backups": "tsx scripts/sync-backups.ts --once",
    "sync:backups:watch": "tsx scripts/sync-backups.ts --watch",
    "sync:backups:poll": "tsx scripts/sync-backups.ts --poll",
    "sync:file": "tsx scripts/sync-backups.ts --file",
    "setup": "tsx scripts/setup-mcp.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.2",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.7.15",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "dotenv": "^17.4.2",
    "duckdb": "^1.4.4",
    "fastify": "^5.3.3",
    "ioredis": "^5.11.1",
    "meilisearch": "^0.58.0",
    "neo4j-driver": "^6.2.0",
    "pg": "^8.22.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^22.15.29",
    "@types/pg": "^8.20.0",
    "@vercel/node": "^5.3.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.1"
  }
}
