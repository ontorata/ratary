{
  "name": "ai-memory-cloud",
  "title": "AI Memory Cloud",
  "description": "Persistent coding memory for AI assistants — save, search, token-efficient context, knowledge graph, multi-client sync. MCP stdio (27 tools) or remote HTTPS.",
  "version": "1.0.0",
  "license": "MIT",
  "repository": "https://github.com/lutfi04/ai-brain",
  "homepage": "https://github.com/lutfi04/ai-brain/tree/main/MCP",
  "categories": ["memory", "development", "productivity"],
  "transports": {
    "stdio": {
      "entry": "src/mcp/stdio.ts",
      "command": "npx",
      "args": ["-y", "tsx", "src/mcp/stdio.ts"]
    },
    "streamable-http": {
      "path": "/mcp",
      "envFlag": "REMOTE_MCP_ENABLED"
    }
  },
  "packages": {
    "npm": "@ai-brain/mcp-server",
    "bin": "ai-brain-mcp"
  },
  "toolCount": 27,
  "toolsRef": "src/capabilities/mcp-tool-names.ts"
}
