{
  "name": "@ratary/sdk",
  "version": "1.0.0",
  "description": "TypeScript client for Ratary REST API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ontorata/ratary.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/ontorata/ratary/tree/main/packages/sdk",
  "bugs": "https://github.com/ontorata/ratary/issues",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
